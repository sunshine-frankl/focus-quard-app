{
  "provider": "python",
  "install": {
    "aptPackages": [
      "libgl1-mesa-glx",
      "libglib2.0-0",
      "libsm6",
      "libxrender1",
      "libxext6",
      "libgomp1"
    ]
  },
  "start": {
    "command": "streamlit run app.py --server.port $PORT --server.address 0.0.0.0 --server.headless true"
  }
}
