{
  "provider": "python",
  "install": {
    "aptPackages": [
      "libgl1-mesa-glx",
      "libglib2.0-0",
      "libsm6",
      "libxrender1",
      "libxext6",
      "libgomp1",
      "libxcb1",
      "libx11-6",
      "libxcb-util1",
      "libxcb-icccm4",
      "libxcb-image0",
      "libxcb-keysyms1",
      "libxcb-randr0",
      "libxcb-render-util0",
      "libxcb-xinerama0",
      "libxcb-xkb1",
      "libxkbcommon-x11-0",
      "libdbus-1-3"
    ]
  },
  "start": {
    "command": "streamlit run app.py --server.port $PORT --server.address 0.0.0.0 --server.headless true"
  }
}
